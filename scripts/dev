#!/bin/bash

# ==============================================================================
# dev - tmux + git worktree 기반 개발 세션 관리 도구
# ==============================================================================
# 각 개발 세션은 독립된 git worktree와 tmux 세션으로 구성된다.
# worktree는 같은 저장소에서 여러 브랜치를 동시에 checkout할 수 있게 해준다.
# 이를 통해 브랜치 전환 없이 여러 작업을 병렬로 진행할 수 있다.
#
# 디렉토리 구조:
#   <repo>/../.worktrees/<repo-name>/<session-name>/  ← git worktree
#   tmux session: dev_<session-name>                  ← tmux 세션
#
# 각 세션의 tmux 창 구성:
#   1. code    : claude (Claude Code AI 어시스턴트)
#   2. gemini  : gemini (Gemini CLI 어시스턴트)
#   3. term    : 일반 셸 (명령 실행용)
#   4. git     : lazygit (git TUI)
#
# 사용법:
#   dev                     # 현재 디렉토리에서 세션 시작 (worktree 없음)
#   dev <name>              # worktree 생성 + tmux 세션 시작
#   dev -l                  # 현재 저장소의 세션 목록 표시
#   dev -c <name>           # 세션 정리 (tmux 종료 + worktree 삭제 + 브랜치 삭제)
#   dev -c --all            # 현재 저장소의 모든 세션 정리
#   dev -c --orphans        # tmux 세션이 없는 orphan worktree 정리
# ==============================================================================

set -e

# 터미널 출력 색상 코드
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'  # 색상 초기화

# 실행 모드 플래그
SESSION_NAME=""
LIST_MODE=false
CLEAN_MODE=false
CLEAN_ALL=false
CLEAN_ORPHANS=false

# ------------------------------------------------------------------------------
# 인자 파싱
# ------------------------------------------------------------------------------
while [[ $# -gt 0 ]]; do
    case $1 in
        -l|--list)
            LIST_MODE=true
            shift
            ;;
        -c|--clean)
            CLEAN_MODE=true
            shift
            ;;
        --all)
            CLEAN_ALL=true
            shift
            ;;
        --orphans)
            CLEAN_ORPHANS=true
            shift
            ;;
        -h|--help)
            echo "Usage: dev [options] [name]"
            echo ""
            echo "Options:"
            echo "  -l, --list              세션 목록 (worktree + tmux 상태)"
            echo "  -c, --clean <name>      세션 정리 (tmux + worktree + 브랜치)"
            echo "  -c --all                현재 저장소의 모든 세션 정리"
            echo "  -c --orphans            tmux 없는 orphan 세션 정리"
            echo "  -h, --help              도움말 표시"
            echo ""
            echo "Examples:"
            echo "  dev                     # 현재 디렉토리에서 세션 시작"
            echo "  dev s1                  # worktree + 세션 생성"
            echo "  dev -l                  # 세션 목록"
            echo "  dev -c s1               # 세션 정리"
            echo "  dev -c --all            # 모든 세션 정리"
            echo "  dev -c --orphans        # orphan 세션 정리"
            exit 0
            ;;
        -*)
            echo -e "${RED}Unknown option: $1${NC}"
            exit 1
            ;;
        *)
            SESSION_NAME="$1"
            shift
            ;;
    esac
done

# ------------------------------------------------------------------------------
# 헬퍼: tmux 세션 존재 여부 확인
# ------------------------------------------------------------------------------
# tmux has-session: 세션이 있으면 exit 0, 없으면 exit 1
# "=이름" 형식은 정확히 일치하는 세션만 검색 (부분 일치 방지)
_tmux_session_exists() {
    tmux has-session -t "=$1" 2>/dev/null
}

# ------------------------------------------------------------------------------
# 헬퍼: 단일 세션 정리
# ------------------------------------------------------------------------------
# 처리 순서: tmux 세션 종료 → git worktree 제거 → git 브랜치 삭제
_clean_session() {
    local name="$1"
    local repo_root="$2"
    # tmux 세션 이름에 공백, 점, 슬래시 사용 불가 → 언더스코어로 대체
    local sanitized=$(echo "$name" | tr ' ./' '_')

    echo -e "${YELLOW}Cleaning up: $name${NC}"

    # 1. tmux 세션 종료
    if _tmux_session_exists "dev_$sanitized"; then
        echo -e "  ${BLUE}Stopping tmux session...${NC}"
        tmux kill-session -t "=dev_$sanitized"
    fi

    # 2. git worktree 및 브랜치 삭제 (repo_root가 있을 때만)
    if [[ -n "$repo_root" ]]; then
        local repo_name=$(basename "$repo_root")
        local worktree_dir="$repo_root/../.worktrees/$repo_name/$name"

        # worktree 디렉토리 제거 (git worktree remove는 git 추적 정보도 정리함)
        if [[ -d "$worktree_dir" ]]; then
            echo -e "  ${BLUE}Removing worktree...${NC}"
            git -C "$repo_root" worktree remove "$worktree_dir" --force 2>/dev/null || true
        fi

        # 세션명과 같은 브랜치 삭제 (없어도 오류 없이 진행)
        if git -C "$repo_root" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
            echo -e "  ${BLUE}Deleting branch...${NC}"
            git -C "$repo_root" branch -D "$name" 2>/dev/null || true
        fi
    fi
}

# ==============================================================================
# 목록 모드 (-l)
# ==============================================================================
# 현재 저장소의 모든 worktree를 순회하여 tmux 세션 상태와 함께 표시
if [[ "$LIST_MODE" == true ]]; then
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -z "$REPO_ROOT" ]]; then
        echo -e "${RED}Error: Not in a git repository${NC}"
        exit 1
    fi

    REPO_NAME=$(basename "$REPO_ROOT")
    WORKTREE_BASE="$REPO_ROOT/../.worktrees/$REPO_NAME"

    if [[ ! -d "$WORKTREE_BASE" ]] || [[ -z "$(ls -A "$WORKTREE_BASE" 2>/dev/null)" ]]; then
        echo "No dev sessions for $REPO_NAME"
        exit 0
    fi

    echo -e "${GREEN}Sessions for ${BLUE}$REPO_NAME${NC}:"
    echo ""

    for wt_dir in "$WORKTREE_BASE"/*/; do
        [[ -d "$wt_dir" ]] || continue
        wt_name=$(basename "$wt_dir")
        sanitized=$(echo "$wt_name" | tr ' ./' '_')
        tmux_name="dev_$sanitized"

        # worktree 내의 현재 브랜치 이름 가져오기
        branch=$(git -C "$wt_dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "?")

        if _tmux_session_exists "$tmux_name"; then
            # tmux 세션이 활성 상태: 창 수 표시
            win_count=$(tmux list-windows -t "=$tmux_name" 2>/dev/null | wc -l | tr -d ' ')
            echo -e "  ${GREEN}*${NC} ${wt_name}  ${DIM}[$branch]${NC}  ${GREEN}${win_count} windows${NC}"
        else
            # tmux 세션 없음: orphan 상태
            echo -e "  ${DIM}-${NC} ${wt_name}  ${DIM}[$branch]  (no tmux)${NC}"
        fi
    done
    echo ""
    exit 0
fi

# ==============================================================================
# 정리 모드 (-c)
# ==============================================================================
if [[ "$CLEAN_MODE" == true ]]; then
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)

    # --- 전체 정리 (--all) ---
    # 현재 저장소의 모든 worktree/세션을 한 번에 정리
    if [[ "$CLEAN_ALL" == true ]]; then
        if [[ -z "$REPO_ROOT" ]]; then
            echo -e "${RED}Error: Not in a git repository${NC}"
            exit 1
        fi
        REPO_NAME=$(basename "$REPO_ROOT")
        WORKTREE_BASE="$REPO_ROOT/../.worktrees/$REPO_NAME"

        if [[ ! -d "$WORKTREE_BASE" ]]; then
            echo "No worktrees to clean for $REPO_NAME"
            exit 0
        fi

        # 정리할 세션 목록 수집
        names=()
        for wt_dir in "$WORKTREE_BASE"/*/; do
            [[ -d "$wt_dir" ]] || continue
            names+=("$(basename "$wt_dir")")
        done

        if [[ ${#names[@]} -eq 0 ]]; then
            echo "No worktrees to clean for $REPO_NAME"
            exit 0
        fi

        echo -e "${YELLOW}Will clean ${#names[@]} sessions for $REPO_NAME:${NC}"
        printf '  %s\n' "${names[@]}"
        echo ""
        read -p "Continue? [y/N] " confirm
        [[ "$confirm" =~ ^[yY]$ ]] || exit 0

        for name in "${names[@]}"; do
            _clean_session "$name" "$REPO_ROOT"
        done
        echo -e "${GREEN}All done!${NC}"
        exit 0
    fi

    # --- Orphan 정리 (--orphans) ---
    # worktree는 있지만 대응하는 tmux 세션이 없는 항목만 정리
    if [[ "$CLEAN_ORPHANS" == true ]]; then
        if [[ -z "$REPO_ROOT" ]]; then
            echo -e "${RED}Error: Not in a git repository${NC}"
            exit 1
        fi
        REPO_NAME=$(basename "$REPO_ROOT")
        WORKTREE_BASE="$REPO_ROOT/../.worktrees/$REPO_NAME"

        if [[ ! -d "$WORKTREE_BASE" ]]; then
            echo "No worktrees to clean for $REPO_NAME"
            exit 0
        fi

        # tmux 세션이 없는 worktree만 orphan으로 분류
        orphans=()
        for wt_dir in "$WORKTREE_BASE"/*/; do
            [[ -d "$wt_dir" ]] || continue
            wt_name=$(basename "$wt_dir")
            sanitized=$(echo "$wt_name" | tr ' ./' '_')
            if ! _tmux_session_exists "dev_$sanitized"; then
                orphans+=("$wt_name")
            fi
        done

        if [[ ${#orphans[@]} -eq 0 ]]; then
            echo "No orphaned sessions for $REPO_NAME"
            exit 0
        fi

        echo -e "${YELLOW}Orphaned sessions (no active tmux):${NC}"
        printf '  %s\n' "${orphans[@]}"
        echo ""
        read -p "Clean up all ${#orphans[@]} orphans? [y/N] " confirm
        [[ "$confirm" =~ ^[yY]$ ]] || exit 0

        for name in "${orphans[@]}"; do
            _clean_session "$name" "$REPO_ROOT"
        done
        echo -e "${GREEN}All done!${NC}"
        exit 0
    fi

    # --- 단일 세션 정리 ---
    if [[ -z "$SESSION_NAME" ]]; then
        echo -e "${RED}Error: 세션 이름을 지정하세요. Usage: dev -c <name>${NC}"
        exit 1
    fi

    _clean_session "$SESSION_NAME" "$REPO_ROOT"
    echo -e "${GREEN}Done!${NC}"
    exit 0
fi

# ==============================================================================
# 세션 시작 모드 (기본)
# ==============================================================================

# 이름이 제공된 경우: git worktree 생성 후 해당 디렉토리에서 세션 시작
if [[ -n "$SESSION_NAME" ]]; then
    REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -z "$REPO_ROOT" ]]; then
        echo -e "${RED}Error: Not in a git repository${NC}"
        exit 1
    fi

    REPO_NAME=$(basename "$REPO_ROOT")
    WORKTREE_DIR="$REPO_ROOT/../.worktrees/$REPO_NAME/$SESSION_NAME"

    if [[ -d "$WORKTREE_DIR" ]]; then
        # 이미 존재하는 worktree 재사용
        echo -e "${YELLOW}Using existing worktree: $WORKTREE_DIR${NC}"
    else
        echo -e "${GREEN}Creating worktree: $SESSION_NAME${NC}"
        mkdir -p "$REPO_ROOT/../.worktrees/$REPO_NAME"

        # 브랜치가 이미 있으면 해당 브랜치로 worktree 생성
        # 없으면 새 브랜치를 생성하면서 worktree 추가
        if git -C "$REPO_ROOT" show-ref --verify --quiet "refs/heads/$SESSION_NAME" 2>/dev/null; then
            git -C "$REPO_ROOT" worktree add "$WORKTREE_DIR" "$SESSION_NAME"
        else
            git -C "$REPO_ROOT" worktree add -b "$SESSION_NAME" "$WORKTREE_DIR"
        fi
    fi

    TARGET_PATH="$WORKTREE_DIR"
else
    # 이름 없이 실행: 현재 디렉토리를 세션 경로로 사용 (worktree 없음)
    TARGET_PATH=$(pwd)
    SESSION_NAME=$(basename "$TARGET_PATH")
fi

# tmux 세션 이름 생성
# 원본 이름은 정리 시 사용 (브랜치/worktree 이름과 일치해야 함)
ORIGINAL_SESSION_NAME="$SESSION_NAME"
# tmux는 세션 이름에 공백, 점, 슬래시를 허용하지 않으므로 언더스코어로 변환
SESSION_NAME=$(echo "$SESSION_NAME" | tr ' ./' '_')
TMUX_SESSION="dev_$SESSION_NAME"

echo -e "${GREEN}Starting: ${BLUE}$SESSION_NAME${NC}"

# ------------------------------------------------------------------------------
# 기존 세션이 있는 경우: attach / restart / stop 선택
# ------------------------------------------------------------------------------
if tmux has-session -t "=$TMUX_SESSION" 2>/dev/null; then
    echo -e "${YELLOW}Session exists.${NC}"

    # fzf가 있으면 fzf 팝업으로 선택, 없으면 숫자 입력으로 선택
    if command -v fzf &>/dev/null; then
        ACTION=$(echo -e "attach\nrestart\nstop" | fzf --height=5 --layout=reverse --prompt="Action: ") || true
    else
        echo "1) attach  2) restart  3) stop"
        read -p "Choose [1-3]: " choice
        case $choice in
            1) ACTION="attach" ;;
            2) ACTION="restart" ;;
            3) ACTION="stop" ;;
            *) ACTION="attach" ;;
        esac
    fi

    case "$ACTION" in
        "attach")
            # 기존 세션에 연결
            tmux attach-session -t "=$TMUX_SESSION"
            exit 0
            ;;
        "restart")
            # 기존 세션 종료 후 새로 시작
            tmux kill-session -t "=$TMUX_SESSION" 2>/dev/null || true
            sleep 0.5
            ;;
        "stop")
            # 세션 완전 정리 (tmux + worktree + 브랜치)
            REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null)
            _clean_session "$ORIGINAL_SESSION_NAME" "$REPO_ROOT"
            echo -e "${GREEN}Stopped.${NC}"
            exit 0
            ;;
        *)
            exit 0
            ;;
    esac
fi

# ------------------------------------------------------------------------------
# 새 tmux 세션 생성
# ------------------------------------------------------------------------------
# tmux 서버가 실행 중이지 않으면 시작한다.
# (tmux-continuum의 자동 복구가 완료될 시간을 주기 위해 1초 대기)
if ! tmux list-sessions 2>/dev/null; then
    tmux start-server
    sleep 1
fi

# 창 1: code - Claude Code AI 어시스턴트 실행
# new-session -d: 백그라운드로 세션 생성 (아직 attach 안 함)
# 첫 실행 시 'claude login' 으로 인증 필요 (브라우저 OAuth)
# 또는 ANTHROPIC_API_KEY 환경 변수를 ~/.zshrc 에 설정
tmux new-session -d -s "$TMUX_SESSION" -n "code" -c "$TARGET_PATH"
tmux send-keys -t "=$TMUX_SESSION:code" "claude" Enter

# 창 2: gemini - Gemini CLI 어시스턴트 실행
tmux new-window -t "=$TMUX_SESSION" -n "gemini" -c "$TARGET_PATH"
tmux send-keys -t "=$TMUX_SESSION:gemini" "gemini" Enter

# 창 3: term - 빈 셸 (일반 명령 실행용)
tmux new-window -t "=$TMUX_SESSION" -n "term" -c "$TARGET_PATH"

# 창 4: git - lazygit TUI 실행
tmux new-window -t "=$TMUX_SESSION" -n "git" -c "$TARGET_PATH"
tmux send-keys -t "=$TMUX_SESSION:git" "lazygit" Enter

# code 창을 첫 번째로 포커스한 상태로 세션에 attach
tmux select-window -t "=$TMUX_SESSION:code"
tmux attach-session -t "=$TMUX_SESSION"
