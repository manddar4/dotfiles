# ==============================================================================
# Git 글로벌 설정
# ==============================================================================
# 이 파일은 dotfiles/git/.gitconfig 에 있으며, ~/.gitconfig 로 심볼릭 링크된다.
# 사용자별 설정(name, email)은 직접 수정하거나 git config --global 명령으로 덮어쓴다.
# ==============================================================================

[user]
	name = nobody
	email = nobody@gmail.com

# ==============================================================================
# alias: 자주 쓰는 명령어 단축키
# ==============================================================================
[alias]
	s = status    # git s → git status
	c = checkout  # git c <branch> → git checkout <branch>

# ==============================================================================
# core: 핵심 동작 설정
# ==============================================================================
[core]
	# git diff, git log 등에서 페이저로 delta를 사용
	# delta: 문법 강조, side-by-side 보기, 줄 번호 등을 지원하는 diff 도구
	pager = delta

	# 기본 편집기를 nvim으로 설정
	# git commit, git rebase -i 등에서 사용됨
	editor = nvim

[init]
	# 새 저장소의 기본 브랜치 이름을 'main'으로 설정
	# (git 기본값은 'master'이므로 명시적으로 지정)
	defaultBranch = main

# ==============================================================================
# pull: 풀 동작 설정
# ==============================================================================
[pull]
	# git pull 시 merge 대신 rebase 사용
	# 커밋 히스토리를 선형으로 유지하여 더 깔끔한 히스토리를 만든다
	rebase = true

# ==============================================================================
# delta: diff 도구 설정
# ==============================================================================
[delta]
	# n/N 키로 diff 헝크(변경 블록) 간 이동
	navigate = true

	# 변경된 줄의 번호를 왼쪽에 표시
	line-numbers = true

	# 변경 전/후를 좌우로 나란히 표시 (side-by-side)
	# 터미널 너비가 충분할 때 가독성이 크게 향상됨
	side-by-side = true

	# 문법 강조에 사용할 색상 테마 (Dracula)
	syntax-theme = Dracula

# ==============================================================================
# interactive: git add -p 등 인터랙티브 모드 설정
# ==============================================================================
[interactive]
	# git add -p (hunk 단위 스테이징) 시에도 delta로 diff를 표시
	# --color-only: delta가 색상만 입히고 텍스트 구조는 변경하지 않음
	diffFilter = delta --color-only

# ==============================================================================
# merge: 병합 설정
# ==============================================================================
[merge]
	# 충돌 표시 형식: diff3 스타일
	# 기본 스타일보다 세 번째 섹션(공통 조상)을 추가로 보여줘서
	# 어디서 갈라졌는지 이해하기 쉬움
	conflictstyle = diff3

# ==============================================================================
# diff: diff 설정
# ==============================================================================
[diff]
	# 이동된 코드를 다른 색상으로 표시
	# 삭제 후 다른 위치에 추가된 코드를 "이동됨"으로 인식하여 구분
	colorMoved = default
